{
  "entities": {
    "User": {
      "title": "User",
      "description": "Teacher or Admin profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student profile",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "name": { "type": "string" },
        "department": { "type": "string" },
        "year": { "type": "string" },
        "teacherId": { "type": "string" }
      },
      "required": ["studentId", "name", "teacherId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late", "sick"] },
        "teacherId": { "type": "string" }
      },
      "required": ["studentId", "date", "status", "teacherId"]
    },
    "Score": {
      "title": "Score",
      "description": "Student score record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "type": { "type": "string", "enum": ["assignment", "midterm", "final", "activity"] },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subjectId", "type", "score", "maxScore", "teacherId"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Course or Subject details",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "level": { "type": "string" },
        "department": { "type": "string" },
        "teacherId": { "type": "string" }
      },
      "required": ["code", "name", "level", "department", "teacherId"]
    },
    "Slide": {
      "title": "Slide",
      "description": "Teaching slide metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "subjectId": { "type": "string" },
        "teacherId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "subjectId", "teacherId"]
    },
    "CourseContent": {
      "title": "CourseContent",
      "description": "Course content or lesson metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "subjectId": { "type": "string" },
        "teacherId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subjectId", "teacherId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student profiles"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subject details"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Score records"
    },
    "/slides/{slideId}": {
      "schema": "Slide",
      "description": "Teaching slides"
    },
    "/course_content/{contentId}": {
      "schema": "CourseContent",
      "description": "Course content"
    }
  }
}
